<?xml version="1.0" encoding="utf-8"?>
<!-- release / 部分机型上需显式允许 ws 明文，避免仅依赖 usesCleartextTraffic 仍握手失败 -->
<network-security-config>
    <base-config cleartextTrafficPermitted="true">
        <trust-anchors>
            <certificates src="system" />
        </trust-anchors>
    </base-config>
</network-security-config>
